# SAR INDUSTRIES NETWORK — Environment Setup
APP_NAME="SAR INDUSTRIES NETWORK"
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME="SAR INDUSTRIES NETWORK"
NEXT_PUBLIC_BRAND_OWNER="SAIFUL ALAM RAFI"
NEXT_PUBLIC_SUPPORT_EMAIL=admin@sarindustriesnetwork.com

# Local database through docker-compose
DATABASE_URL="postgresql://sar_network:sar_network@localhost:5432/sar_network?schema=public"

# Security
AUTH_SECRET="replace-with-long-random-secret-before-production"
JWT_SECRET="replace-with-long-random-jwt-secret-before-production"

# Default seeded super admin
DEFAULT_ADMIN_NAME="SAIFUL ALAM RAFI"
DEFAULT_ADMIN_EMAIL="admin@sarindustriesnetwork.com"
DEFAULT_ADMIN_PASSWORD="Admin@2026"

# Redis / Queue
REDIS_URL="redis://localhost:6379"

# Email
RESEND_API_KEY=""
EMAIL_FROM="SAR INDUSTRIES NETWORK <admin@sarindustriesnetwork.com>"

# Storage / Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="sar-industries-network"
R2_PUBLIC_URL=""

# Analytics and monitoring
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN=""

# AI Copilot. Keep disabled until API key is configured.
AI_PROVIDER="disabled"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Domain system
PLATFORM_DOMAIN="localhost"
FREE_SUBDOMAIN_MODE="false"

# Official white-label footer
NEXT_PUBLIC_RIGHTS_NOTICE="© 𝟮𝟬𝟮𝟲 𝗔𝗹𝗹 𝗥𝗶𝗴𝗵𝘁𝘀 𝗥𝗲𝘀𝗲𝗿𝘃𝗲𝗱 | 𝗦𝗔𝗥 𝗜𝗡𝗗𝗨𝗦𝗧𝗥𝗜𝗘𝗦 𝗡𝗘𝗧𝗪𝗢𝗥𝗞™."
