    "nuclear:all": "python scripts/sar_nuclear_manager.py all"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.19.1",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "typescript": "5.9.2"
  }
}
